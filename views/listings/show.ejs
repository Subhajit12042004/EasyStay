<% layout('/layouts/boilerplate') -%>
<div class="row mt-3">
    <div class="col-8 offset-2">
<!-- <body> -->
   
    <h3><%=listing.title %></h3>
    </div>
  <div class="card col-6 offset-2" >
  <img src="<%= listing.image.url %>" class="card-img-top show-image" alt="listing_image">
  <div class="card-body">
    <p class="card-text">
      <br>
    
    <%=listing.description %><br>
    &#8377; <%=listing.price.toLocaleString("en-IN") %><br>
    <%=listing.location %><br>
    <%=listing.country %>
</p>
  </div>
  <br></br>
  </div>
<br></br>

<div class="btns mb-3">
        <a href="/listings/<%=listing._id%>/edit"
             class="btn btn-dark col-1 offset-2 add-edit">Edit</a>
        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
         <button class="btn btn-dark offset-4">Delete</button>
       </form>
</div>

<hr/>

<div class="card col-6 offset-2 mb-2 mt-2">
  <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate  class="needs-validation">
    <!-- <div class="mb-2 mt-3">
      <label for="rating" class="form-lavel">Rating</label>
      <input type="range" mini ="1" max="5" id ="rating" name ="review[rating]">

    </div> -->
  <h4> Review</h4>
    <div class="">
      <label class="form-label"></label>

      <div class="star-rating">
        <input type="radio" id="5-stars" name="review[rating]" value="5" required>
        <label for="5-stars">★</label>

        <input type="radio" id="4-stars" name="review[rating]" value="4">
        <label for="4-stars">★</label>

        <input type="radio" id="3-stars" name="review[rating]" value="3">
        <label for="3-stars">★</label>

        <input type="radio" id="2-stars" name="review[rating]" value="2">
        <label for="2-stars">★</label>

        <input type="radio" id="1-star" name="review[rating]" value="1">
        <label for="1-star">★</label>
      </div>
    </div>

    <div class="mb-2">
      <label for="comment" class="form-lavel">Comments</label>
      <textarea name = "review[comment]" id="comment" cols="20" rows="5" class="form-control" required></textarea>
      <div class="invalid-feedback"> please add some comment for review</div>

    </div class="mb-2 mt-3">
    <button class="btn btn-outline-dark">Submit</button>
  </form>
    

</div>

</div>
<br></br>

